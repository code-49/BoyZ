    <p class="product-heading">Explore</p>
    <div class="division"></div>
    
    <div class="category-heading">
        <h3>Shirts</h3> 
        <a href="/products?cat=shirts">VIEW ALL</a>
    </div>
    <div class="product-container">
        <% for (let i = 0; i < shirts.length; i++) {%>
            <div class="product-card">
                <a href="/product?id=<%= shirts[i]._id %>">
                    <div class="image-container-2">
                        <img src="/productImages/<%= shirts[i].images[0] %>" alt="product-img" width="100%" height="100%">
                    </div>
                </a>
                <h3 class="product-name"><%= shirts[i].name %></h3>
                <h3 class="product-name">$<%= shirts[i].price %><span class="offer-style"><%= shirts[i].discount %>%</span></h3>
            </div>
            
        <%} %>
        
    </div>
