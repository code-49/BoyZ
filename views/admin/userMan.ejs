<%- include("../partials/head.ejs") %>
<%- include("../partials/menu.ejs") %>
    
<div class="container">
<%- include("../partials/sidebar.ejs") %>

    <div class="management-content" id="content">

        <div class="category-content">

            <div class="category-lists">
                <table class="category-table">
                    <tr class="category-row">
                        <th>Name</th>
                        <th>Email</th>
                        <th>Verified</th>
                        <th>Block</th>
                    </tr>
                    <% for (let i = 0; i < userList.length; i++) {%>
                        <tr>
                        <td><%=userList[i].name%></td>
                        <td><%=userList[i].email%></td>
                        <td><%=userList[i].is_verified%></td>
                        <td> 
                           <% if(userList[i].blocked == true){%>
                            <a href="/admin/unblock?id=<%= userList[i]._id%>" class=" icon-btn bg-green">unblock</a>
                            <% }else{ %>
                            <a href="/admin/block?id=<%= userList[i]._id%>" class=" icon-btn bg-red">block</a>
                            <% } %>
                                
                                
                        </td>
                        </tr>
                    <%} %>
                    
                </table>
                
            </div>
    </div>
</div>
 
<%- include("../partials/footer.ejs") %>
